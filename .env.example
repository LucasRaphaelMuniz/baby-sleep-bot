# ─── LLM (via LiteLLM) ───────────────────────────────────────────────
# Troque o provedor mudando o modelo + a chave correspondente.
# Exemplos: anthropic/claude-sonnet-4-6 | openai/gpt-4.1 | gemini/gemini-2.0-flash
LLM_MODEL=anthropic/claude-sonnet-4-6
# Chave do provedor escolhido (use a variável que o LiteLLM espera):
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─── WhatsApp — escolha do provedor ──────────────────────────────────
# 'meta' (Cloud API) ou 'twilio'. Define qual backend os lembretes usam para
# enviar; no webhook, basta apontar o painel do provedor para a rota dele.
WHATSAPP_PROVIDER=meta

# ── Provedor 1: Meta Cloud API (https://developers.facebook.com) ──
WHATSAPP_PHONE_NUMBER_ID=        # ID do número (não é o número em si)
WHATSAPP_TOKEN=                  # token de acesso (use um System User p/ não expirar)
WHATSAPP_VERIFY_TOKEN=           # string que VOCÊ escolhe; usada na verificação do webhook
WHATSAPP_APP_SECRET=             # app secret (valida assinatura X-Hub-Signature-256)
WHATSAPP_VALIDATE=true           # 'false' p/ testar local sem validar assinatura

# ── Provedor 2: Twilio (https://www.twilio.com) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # número/sandbox do Twilio
TWILIO_VALIDATE=true             # 'false' p/ testar local sem validar assinatura

# ─── App ─────────────────────────────────────────────────────────────
TIMEZONE=America/Sao_Paulo
WAKE_WINDOWS_PATH=config/wake_windows.yaml
# PORT é injetado pelo Railway automaticamente; defina apenas em local se quiser.
# PORT=8000
